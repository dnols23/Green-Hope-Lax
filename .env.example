# ─────────────────────────────────────────────────────────────────────────────
# Green Hope Falcons Lacrosse — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Data API (URL) and API Keys.
# The URL and ANON key are public (sent to the browser). The SERVICE ROLE key
# is SECRET — it bypasses Row Level Security. Only ever used server-side.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Email notifications (Resend) ──────────────────────────────────────────────
# Create a free account at https://resend.com, add+verify a domain (or use the
# resend.dev sandbox), then create an API key. Optional: if RESEND_API_KEY is
# blank, the site still works — it just skips sending the coach email.
RESEND_API_KEY=

# The "from" address Resend sends as. Must be on a domain you've verified in
# Resend. For testing you can use onboarding@resend.dev.
EMAIL_FROM=Green Hope Falcons <noreply@yourdomain.com>

# Where new interest-form / contact submissions get emailed (you, the coach).
# Comma-separate multiple recipients.
COACH_NOTIFY_EMAIL=coach@yourdomain.com

# ── Public site URL (used in emails / social cards) ───────────────────────────
NEXT_PUBLIC_SITE_URL=https://greenhopelacrosse.com

# ── Optional: Google Sheets sync ──────────────────────────────────────────────
# Only needed if you set up the Supabase Edge Function that appends new form
# rows to a Google Sheet (see README → "Option B: Google Sheets sync").
# These are configured as Supabase Edge Function secrets, NOT here — listed for
# reference only:
#   GOOGLE_SERVICE_ACCOUNT_EMAIL=...
#   GOOGLE_PRIVATE_KEY=...
#   GOOGLE_SHEET_ID=...
